{
  "name": "@solidstate/hardhat-accounts",
  "version": "2.0.2",
  "description": "Output accounts with Hardhat",
  "keywords": [
    "hardhat",
    "buidler",
    "accounts",
    "ethers",
    "smart-contracts",
    "ethereum",
    "blockchain",
    "wow"
  ],
  "repository": "github:solidstate-network/hardhat-accounts",
  "license": "MIT",
  "author": "Nick Barry",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "src/"
  ],
  "scripts": {
    "build": "pnpm clean && tsc --build",
    "clean": "rm -rf dist/",
    "prepare": "husky",
    "prepublishOnly": "pnpm build",
    "prettier": "prettier --write .",
    "test": "pnpm clean && tsx --test --experimental-test-coverage"
  },
  "dependencies": {
    "@solidstate/hardhat-solidstate-utils": "^1.0.2",
    "chalk": "^5.6.2"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^25.9.2",
    "exec-staged": "^0.2.3",
    "hardhat": "^3.8.0",
    "husky": "^9.1.7",
    "knip-exec-staged": "^5.63.1",
    "prettier": "^3.8.3",
    "prettier-plugin-packagejson": "^3.0.2",
    "release-it": "^20.2.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "ethers": "^6.14.1",
    "hardhat": "^3.8.0",
    "viem": "^2.29.4"
  },
  "peerDependenciesMeta": {
    "ethers": {
      "optional": true
    },
    "viem": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
